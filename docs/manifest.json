{
  "manifest_version": 3,
  "name": "Thai Neologism Translator",
  "version": "1.0.0",
  "description": "แปลภาษาเด็กแว้นบนโซเชียลมีเดียเป็นภาษาไทยมาตรฐาน",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Thai Neologism Translator"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://www.tiktok.com/*",
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
